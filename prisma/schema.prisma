generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. K-Destiny 독자적 사주 해석 콘텐츠 딕셔너리 (우리의 지적 재산 IP)
model SajuContentDictionary {
  id             String   @id @default(uuid())
  category       String
  signKey        String
  englishContent String   @db.Text
  remedyAction   String?  @db.Text
  updatedAt      DateTime @updatedAt

  @@unique([category, signKey])
}

// 2. 유저 명식 데이터베이스 (재계산 방지 및 PII 보호 구역)
model UserSajuProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthHash     String?
  gender        String
  fourPillars   Json
  dayMaster     String
  elementsScore Json
  createdAt     DateTime @default(now())
}

// 3. 사용자 및 권한 관리
enum Role {
  USER
  ADMIN
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  role        Role             @default(USER)
  tier        SubscriptionTier @default(FREE)
  usageTokens Int              @default(3)

  // SaaS Subscription Management
  planType           String? // '1_MONTH', '3_MONTHS', '6_MONTHS', '1_YEAR'
  paidAmount         Int? // Amount paid in cents (e.g., 9900 = $99.00)
  premiumStartDate   DateTime?
  premiumEndDate     DateTime?
  subscriptionStatus String?   @default("NONE") // 'NONE', 'ACTIVE', 'EXPIRED', 'CANCELLED'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles UserSajuProfile[]
  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 4. Hermes AI Agent — Telegram 연동 데이터
model TelegramAccount {
  id              String            @id @default(cuid())
  telegramId      String            @unique
  username        String?
  firstName       String?
  lastName        String?
  userId          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  TelegramMessage TelegramMessage[]
}

model TelegramMessage {
  id                String          @id @default(cuid())
  telegramAccountId String
  direction         String
  telegramMessageId String?
  text              String?
  payload           Json?
  createdAt         DateTime        @default(now())
  TelegramAccount   TelegramAccount @relation(fields: [telegramAccountId], references: [id], onDelete: Cascade)
}
