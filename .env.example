# K-Destiny environment variables — SAFE TEMPLATE (no secrets).
# Copy to `.env.local` (gitignored) and fill in real values. Never commit real keys.
# Only NEXT_PUBLIC_* are exposed to the browser; everything else is SERVER-ONLY.

# ── Database (Supabase Postgres) — SERVER ONLY ──
# Contains the DB password. If this ever leaks, ROTATE the password in Supabase.
DATABASE_URL="postgresql://user:PASSWORD@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:PASSWORD@host:5432/postgres"

# ── AI (paid Gemini tier) — SERVER ONLY ──
GEMINI_API_KEY=""

# ── Auth (NextAuth + Google OAuth) — SERVER ONLY ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Payments (Gumroad) — SERVER ONLY ──
GUMROAD_SELLER_ID=""
GUMROAD_WEBHOOK_SECRET=""

# ── Rate limiting (Upstash Redis) — SERVER ONLY ──
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Hermes internal agent — SERVER ONLY ──
HERMES_SECRET=""

# ── Supabase client keys ──
NEXT_PUBLIC_SUPABASE_URL=""       # public (safe in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""  # public anon key (safe in browser; RLS-protected)
SUPABASE_SERVICE_ROLE_KEY=""      # ADMIN key — SERVER ONLY, bypasses RLS. Never expose.

# ── Analytics ──
NEXT_PUBLIC_GA_ID=""              # public GA4 measurement id (e.g. G-XXXXXXXXXX)
