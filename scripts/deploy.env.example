# Copy this file to `scripts/deploy.env` and fill in real values.
# `scripts/deploy.env` is gitignored — the real password never enters git.
#
#   cp scripts/deploy.env.example scripts/deploy.env
#   # then edit scripts/deploy.env with your NEW password
#
# All deploy/SSH scripts read credentials from here via scripts/_creds.py.

DEPLOY_HOST=161.97.134.176
DEPLOY_USER=root
DEPLOY_PASS=your-new-server-password-here

# Only needed by scripts/set_env.py (pushes the key to the server .env):
# OPENAI_API_KEY=sk-...
